# Copy this file to .env and fill in real values.
# NEVER commit .env to git — it contains secrets!

# Backend base URL (no trailing slash)
BACKEND_URL=https://api.pokyh.com

# API key — required on every request (X-API-Key header)
BACKEND_API_KEY=your_api_key_here

# Server key — used only for /auth/login (X-Server-Key header)
BACKEND_SERVER_KEY=your_server_key_here

# Android signing — keystore as base64 (ask team lead for the real value)
KEYSTORE_BASE64=your_base64_encoded_keystore_here
KEYSTORE_STORE_PASSWORD=your_store_password
KEYSTORE_KEY_ALIAS=your_key_alias
KEYSTORE_KEY_PASSWORD=your_key_password
