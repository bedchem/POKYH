rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admins – nur über Firebase Console beschreibbar
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Benutzerprofil – Benutzername + UID für Mitgliederliste
    match /users/{uid} {
      // Jeder eingeloggte User darf Benutzernamen lesen (für Mitgliederliste)
      allow read: if request.auth != null;
      // Nur der User selbst darf seinen eigenen Eintrag schreiben
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Bewertungen für Mensa-Gerichte
    match /dish_ratings/{dishId} {
      // Jeder eingeloggte User kann Durchschnitt und Anzahl lesen
      allow read: if request.auth != null;
      // Aggregat (Durchschnitt + Anzahl) darf jeder eingeloggte User schreiben
      allow write: if request.auth != null;

      match /votes/{uid} {
        // User darf nur die eigene Stimme lesen/schreiben
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Klassen
    match /classes/{classId} {
      // Lesen: jeder eingeloggte User (für Code-Suche)
      allow read: if request.auth != null;

      // Erstellen: nur Admins (doc in /admins/{uid} muss existieren)
      allow create: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));

      // Update: members und memberNames (beitreten / verlassen)
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'memberNames']);

      // Löschen: erlaubt wenn keine Mitglieder mehr (nach Verlassen)
      allow delete: if request.auth != null
        && resource.data.members.size() == 0;

      // Erinnerungen – Mitglieder dürfen alles
      match /reminders/{reminderId} {
        allow read, create, delete: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/classes/$(classId)).data.members;
        allow update: if false;
      }
    }
  }
}
