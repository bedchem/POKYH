rules_version = '2';

// Helper: Gibt die stableUid des aktuellen Users zurück.
// Schaut in users/{firebaseUid}.stableUid – das ist die geräteübergreifende ID.
// Fallback: request.auth.uid (für Abwärtskompatibilität).

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Admins ────────────────────────────────────────────────────────────────
    // Admin-Dokumente: admins/{stableUid} mit canCreateClass: true
    // Lesen erlaubt wenn: eigene Firebase-UID stimmt, ODER stableUid stimmt
    match /admins/{adminId} {
      allow read: if request.auth != null && (
        request.auth.uid == adminId
        || get(/databases/$(database)/documents/users/$(request.auth.uid))
             .data.get('stableUid', '') == adminId
      );
      allow write: if false;
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    // users/{firebaseUid} → gerätespezifisch, enthält stableUid
    // users/{username}    → geräteübergreifend, enthält stableUid
    match /users/{userId} {
      allow read: if request.auth != null;
      // Eigenes Firebase-UID-Dokument: immer erlaubt
      allow write: if request.auth != null && request.auth.uid == userId;
      // Username-Dokument: Erstellen nur wenn noch nicht vorhanden (erster Login)
      allow create: if request.auth != null
        && !exists(/databases/$(database)/documents/users/$(userId));
      // Username-Dokument: Aktualisieren nur wenn es das eigene Username-Dokument ist
      allow update: if request.auth != null && (
        request.auth.uid == userId
        || get(/databases/$(database)/documents/users/$(request.auth.uid))
             .data.get('username', '') == userId
      );
    }

    // ── Mensa-Bewertungen ─────────────────────────────────────────────────────
    match /dish_ratings/{dishId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;

      match /votes/{voteId} {
        // Erlaubt wenn voteId == Firebase-UID (alt) ODER voteId == stableUid (neu)
        allow read, write: if request.auth != null && (
          request.auth.uid == voteId
          || get(/databases/$(database)/documents/users/$(request.auth.uid))
               .data.get('stableUid', '') == voteId
        );
      }
    }

    // ── Klassen ───────────────────────────────────────────────────────────────
    match /classes/{classId} {
      allow read: if request.auth != null;

      // Erstellen: automatisch (WebUntis-Klasse mit webuntisKlasseId) ODER Admin
      allow create: if request.auth != null && (
        request.resource.data.keys().hasAll(['webuntisKlasseId'])
        || exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        || exists(/databases/$(database)/documents/admins/$(
             get(/databases/$(database)/documents/users/$(request.auth.uid))
               .data.get('stableUid', '__none__')
           ))
      );

      // Update: beitreten / verlassen (nur members + memberNames)
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['members', 'memberNames']);

      // Löschen: wenn keine Mitglieder mehr
      allow delete: if request.auth != null
        && resource.data.members.size() == 0;

      // ── Erinnerungen ──────────────────────────────────────────────────────
      match /reminders/{reminderId} {
        // Erlaubt wenn stableUid des Users in class.members ist
        allow read, create, delete: if request.auth != null && (
          get(/databases/$(database)/documents/users/$(request.auth.uid))
            .data.get('stableUid', request.auth.uid)
            in get(/databases/$(database)/documents/classes/$(classId)).data.members
        );
        allow update: if false;
      }
    }

    // ── Persönliche Todos (alt: user_todos/{stableUid}) ──────────────────────
    match /user_todos/{stableUid}/todos/{todoId} {
      allow read, write: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid))
          .data.get('stableUid', request.auth.uid) == stableUid
      );
    }

    // ── Persönliche Todos (neu: users/{username}/todos/{todoId}) ─────────────
    // Die App speichert Todos unter users/{username}/todos – erlaubt wenn
    // der eingeloggte Firebase-User diesen Username besitzt.
    match /users/{userId}/todos/{todoId} {
      allow read, write: if request.auth != null && (
        request.auth.uid == userId
        || get(/databases/$(database)/documents/users/$(request.auth.uid))
             .data.get('username', '') == userId
      );
    }
  }
}
